# Copy this file to .env and fill in your values.
#
# Scholar is provider-agnostic (via LiteLLM) and runs entirely on free-tier
# LLM providers. Only ONE key is required to get started: GEMINI_API_KEY.
# The other two are optional automatic fallbacks -- if Gemini's free tier
# is rate-limited or unavailable, Scholar automatically retries with
# OpenRouter's free model, then Groq, in that order.
#
# Get free keys here:
#   Gemini (AI Studio):  https://aistudio.google.com/apikey
#   OpenRouter:           https://openrouter.ai/keys
#   Groq:                 https://console.groq.com/keys

# --- Priority 1: Gemini (required for the default setup) ---
GEMINI_API_KEY=your-gemini-api-key-here

# --- Priority 2: OpenRouter free model (optional fallback) ---
OPENROUTER_API_KEY=

# --- Priority 3: Groq (optional fallback) ---
GROQ_API_KEY=

# --- Model overrides (optional -- sensible free-tier defaults are used otherwise) ---
SCHOLAR_GEMINI_MODEL=gemini/gemini-2.5-flash
SCHOLAR_OPENROUTER_MODEL=openrouter/meta-llama/llama-3.1-8b-instruct:free
SCHOLAR_GROQ_MODEL=groq/llama-3.1-8b-instant

# --- Token limits per agent ---
SCHOLAR_PLANNER_MAX_TOKENS=1024
SCHOLAR_SUMMARIZER_MAX_TOKENS=512
SCHOLAR_CRITIQUE_MAX_TOKENS=1024
SCHOLAR_WRITER_MAX_TOKENS=2048

# --- RAG / embeddings (fully local, no API key needed) ---
SCHOLAR_EMBEDDING_MODEL=all-MiniLM-L6-v2
SCHOLAR_CHUNK_SIZE=800
SCHOLAR_CHUNK_OVERLAP=120
SCHOLAR_TOP_K=4

# --- Pipeline behavior ---
SCHOLAR_MAX_PAPERS=8
SCHOLAR_MAX_WRITER_REVISIONS=2
SCHOLAR_MAX_RETRIES=3
SCHOLAR_RETRY_BASE_DELAY=1.5

# --- Misc ---
SCHOLAR_CACHE_DIR=data/cache
SCHOLAR_LOG_LEVEL=INFO
